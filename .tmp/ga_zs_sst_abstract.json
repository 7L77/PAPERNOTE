{"userInfo":{"customerNameRaw":"SHENZHEN UNIVERSITY","institutionName":"SHENZHEN UNIVERSITY","authType":["ipv6"],"institute":true,"member":false,"individual":false,"guest":false,"subscribedContent":false,"fileCabinetContent":false,"fileCabinetUser":false,"institutionalFileCabinetUser":false,"products":"PUP:1945:2023|RIVER:2001:2023|NOW:2004:2023|PACKT:1872:2023|EBOOKS:1974:2024|WILEY_DATA_CYBERSEC:2014:2024|WILEYTELECOM:2005:2024|WILEYAI:1872:2025|MANNING:1872:2025|IEL|VDE|NOKIA BELL LABS|","instType":"Academic","userIds":[12631],"showPatentCitations":true,"showGet802Link":true,"openUrlImgLoc":"/assets/img/btn.find-in-library.png","openUrlLink":"NA","showOpenUrlLink":false,"tracked":false,"ringGoldId":"47890","institutionUserId":12631,"delegatedAdmin":false,"desktop":false,"isInstitutionDashboardEnabled":false,"isInstitutionProfileEnabled":false,"isRoamingEnabled":true,"isDelegatedAdmin":false,"isMdl":false,"isCwg":false,"isAcademic":true,"isReadAndPublish":false,"isIel":true},"authors":[{"name":"Jun-Hua Ko","affiliation":["National Taiwan University, Taipei, Taiwan"],"ringgoldId":"33561","firstName":"Jun-Hua","lastName":"Ko","id":"37089712279"},{"name":"Tzi-Dar Chiueh","affiliation":["National Taiwan University, Taipei, Taiwan"],"ringgoldId":"33561","firstName":"Tzi-Dar","lastName":"Chiueh","id":"37087157344"}],"isbn":[{"format":"Electronic ISBN","value":"979-8-3315-1042-8","isbnType":""},{"format":"Print on Demand(PoD) ISBN","value":"979-8-3315-1043-5","isbnType":""}],"issn":[{"format":"Electronic ISSN","value":"2161-4407"},{"format":"Print on Demand(PoD) ISSN","value":"2161-4393"}],"articleNumber":"11229357","mediaPath":"/mediastore/IEEE/content/media/11227166/11227148/11229357","getProgramTermsAccepted":false,"sections":{"abstract":"true","authors":"true","disclaimer":"false","figures":"true","multimedia":"false","references":"true","citedby":"false","keywords":"true","definitions":"false","algorithm":"false","dataset":"false","cadmore":"false","footnotes":"false","relatedContent":"false"},"abstract":"Neural Architecture Search (NAS) aims to automate the design of neural networks, enabling the discovery of highly effective architectures. Recent advancements in NAS have shown significant success in identifying high-performing Transformer architectures for computer vision and natural language processing tasks. However, most NAS research has focused on supervised learning frameworks, which rely heavily on labeled data. This dependence on labeled data makes deploying these methods in real-world applications challenging due to the high cost of data annotation. Additionally, previous studies often prioritize model performance while neglecting generalization ability, particularly in scenarios with limited labeled data. To address these challenges, this study introduces a generalization-aware zero-shot proxy based on self-supervised learning. By combining this proxy with a complementary zero-shot proxy, we identify architectures that balance generalization ability and expressivity. Experimental results demonstrate that the architectures discovered using the proposed approach achieve competitive performance on the ImageNet and Wikitext-2 datasets while significantly reducing the required labeled data by up to 75% and 99%, respectively.","publicationDate":"30 June 2025","pdfPath":"/iel8/11227166/11227148/11229357.pdf","publicationYear":"2025","displayPublicationTitle":"2025 International Joint Conference on Neural Networks (IJCNN)","formulaStrippedArticleTitle":"Generalization-Aware Zero-Shot Neural Architecture Search for Self-Supervised Transformers","pdfUrl":"/stamp/stamp.jsp?tp=&arnumber=11229357","startPage":"1","endPage":"8","publicationTitle":"2025 International Joint Conference on Neural Networks (IJCNN)","keywords":[{"type":"IEEE Keywords","kwd":["Computer vision","Costs","Annotations","Supervised learning","Neural networks","Computer architecture","Self-supervised learning","Transformers","Natural language processing","Neural architecture search"]},{"type":"Index Terms","kwd":["Neural Architecture","Neural Architecture Search","Model Performance","Supervised Learning","Generalization Ability","Self-supervised Learning","Natural Language Processing Tasks","Transformer Architecture","Spearman Correlation","Eigenvalues","Computational Complexity","Superior Performance","Population Of Individuals","Image Classification","Search Space","Singular Value","Semantic Segmentation","Feature Matrix","Entropy Score","Number Of Heads","Vision Transformer","Forward Propagation","Parameter Count","Architecture Parameters","Embedding Dimension","Human Experts"]},{"type":"Author Keywords","kwd":["Neural Architecture Search","Self-Supervised Learning","Computer Vision","Natural Language Processing"]}],"doiLink":"https://doi.org/10.1109/IJCNN64981.2025.11229357","issueLink":"/xpl/tocresult.jsp?isnumber=11227148&punumber=11227166","pubLink":"/xpl/conhome/11227166/proceeding","allowComments":false,"dateOfInsertion":"14 November 2025","authorNames":"Jun-Hua Ko;Tzi-Dar Chiueh","rightsLink":"http://s100.copyright.com/AppDispatchServlet?publisherName=ieee&publication=proceedings&title=Generalization-Aware+Zero-Shot+Neural+Architecture+Search+for+Self-Supervised+Transformers&isbn=979-8-3315-1042-8&publicationDate=30+June+2025&author=Jun-Hua+Ko&ContentID=10.1109/IJCNN64981.2025.11229357&orderBeanReset=true&startPage=1&endPage=8&proceedingName=2025+International+Joint+Conference+on+Neural+Networks+%28IJCNN%29","articleCopyRight":"2025 IEEE","displayPublicationDate":"30 June 2025 - 05 July 2025","isGetAddressInfoCaptured":false,"isMarketingOptIn":false,"pubTopics":[{"name":"Components, Circuits, Devices and Systems"},{"name":"Computing and Processing"},{"name":"Power, Energy and Industry Applications"},{"name":"Robotics and Control Systems"},{"name":"Signal Processing and Analysis"}],"publisher":"IEEE","displayDocTitle":"Generalization-Aware Zero-Shot Neural Architecture Search for Self-Supervised Transformers","